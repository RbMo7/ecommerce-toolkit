{
  "name": "@ecommerce-toolkit/fulfillment-tracker",
  "version": "0.1.0",
  "description": "Monitor order fulfillment pipeline status, detect SLA breaches and bottlenecks",
  "type": "module",
  "main": "dist/index.js",
